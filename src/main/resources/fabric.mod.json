{
	"schemaVersion": 1,
	"id": "saddle",
	"version": "${version}",
	"name": "Saddle",
	"description": "Debug Adapter Protocol (DAP) server for debugging Minecraft datapack functions from editors like VS Code: breakpoints, stepping, call stacks and command evaluation.",
	"authors": [
		"d1n0"
	],
	"contact": {},
	"license": "MIT",
	"icon": "assets/saddle/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"me.d1n0.saddle.Saddle"
		],
		"client": [
			"me.d1n0.saddle.SaddleClient"
		]
	},
	"mixins": [
		"saddle.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.0",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	},
	"accessWidener": "saddle.classtweaker"
}
